# Copy to .env and adjust. Never commit .env.

# ---- ClickHouse ----
CLICKHOUSE_DB=argus
CLICKHOUSE_USER=argus
CLICKHOUSE_PASSWORD=argus
CLICKHOUSE_HTTP_URL=http://localhost:8123

# ---- Postgres ----
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
DATABASE_URL=postgres://argus:argus@localhost:5433/argus

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO / S3 ----
MINIO_ROOT_USER=argus
MINIO_ROOT_PASSWORD=argus-secret
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=argus-payloads

# ---- Detection service ----
DETECTION_URL=http://localhost:8000
# Optional L2 classifier models (Phase 1 ships heuristics; models are pluggable)
DETECTION_ENABLE_L2=false
# Optional L3 judge (any OpenAI-compatible endpoint)
JUDGE_ENDPOINT=
JUDGE_API_KEY=
JUDGE_MODEL=

# ---- Ingestion API ----
INGEST_PORT=3001
